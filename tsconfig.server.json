{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "isolatedModules": true,
        "allowJs": true,
        "outDir": "dist",
        "noEmit": false,
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "include": [
        "server.ts",
        "src/types.ts",
        "src/constants.ts"
    ]
}